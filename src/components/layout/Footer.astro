---
const year = new Date().getFullYear();
---

<footer
	class="mt-auto flex w-full flex-row items-center justify-between pt-20 pb-8 text-xs text-gray-500 dark:text-gray-400"
>
	<div class="text-left">
		© Young Sang Choi {year}
	</div>
	<nav aria-label="Back to top">
		<button
			id="to-top-btn"
			class="transition-colors hover:text-gray-900 dark:hover:text-gray-100"
			onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
		>
			Top ↑
		</button>
	</nav>
</footer>
