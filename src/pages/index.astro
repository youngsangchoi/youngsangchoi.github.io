---
import PageLayout from "@/layouts/Base.astro";

interface Publication {
	title: string;
	authors: string;
	venue: string;
	links: { text: string; href: string }[];
	bibtex?: string;
}

const publications: Publication[] = [
	{
		title: "ICYM<sup>2</sup>I: The Illusion of Multimodal Informativeness under Missingness",
		authors: "Young Sang Choi*, Vincent Jeanselme*, Pierre Elias, and Shalmali Joshi",
		venue: "ICLR 2026",
		links: [
			{ text: "arXiv →", href: "https://arxiv.org/abs/2505.16953" },
			{ text: "Code →", href: "https://github.com/reAIM-Lab/ICYM2I" },
			{ text: "OpenReview →", href: "https://openreview.net/forum?id=jC7FK8Rf4s" },
		],
		bibtex: `@inproceedings{choi2026icymi,\ntitle={{ICYM}2I: The illusion of multimodal informativeness under missingness},\nauthor={Young Sang Choi and Vincent Jeanselme and Pierre Elias and Shalmali Joshi},\nbooktitle={The Fourteenth International Conference on Learning Representations},\nyear={2026},\nurl={https://openreview.net/forum?id=jC7FK8Rf4s}\n}`,
	},
	{
		title: "FoMoH: A Clinically Meaningful Foundation Model Evaluation",
		authors:
			"Chao Pang*, Vincent Jeanselme*, Young Sang Choi, Xinzhuo Jiang, Zilin Jing, Aparajita Kashyap, Yuta Kobayashi, Yanwei Li, Florent Pollet, Karthik Natarajan, and Shalmali Joshi",
		venue: "Preprint 2025",
		links: [
			{ text: "arXiv →", href: "https://arxiv.org/abs/2505.16941" },
			{ text: "Code →", href: "https://github.com/reAIM-Lab/ehr_foundation_model_benchmark" },
		],
		bibtex: `@article{pang2025fomoh,\ntitle={FoMoH: A clinically meaningful foundation model evaluation for structured electronic health records},\nauthor={Pang, Chao and Jeanselme, Vincent and Choi, Young Sang and Jiang, Xinzhuo and others},\njournal={arXiv preprint arXiv:2505.16941},\nyear={2025}\n}`,
	},
];
---

<PageLayout meta={{ title: "Home" }}>
	<section class="max-w-2xl leading-relaxed text-gray-500 dark:text-gray-400">
		<div class="mb-6 space-y-6">
			<p>
				Young Sang "Young" Choi is a doctoral student advised by <a
					href="https://reaim-lab.github.io/shalmalijoshi.html"
					class="font-bold text-gray-900 underline decoration-solid underline-offset-4 dark:text-gray-100"
					target="_blank"
					rel="noopener noreferrer">Dr. Shalmali Joshi</a
				> and <a
					href="https://pierreelias.github.io/Elias_Bio.html"
					class="font-bold text-gray-900 underline decoration-solid underline-offset-4 dark:text-gray-100"
					target="_blank"
					rel="noopener noreferrer">Dr. Pierre Elias</a
				> at Columbia University.
			</p>

			<p>
				His research sits on the intersection of <strong
					class="font-bold text-gray-900 dark:text-gray-100">multimodal learning</strong
				>, <strong class="font-bold text-gray-900 dark:text-gray-100">event stream modeling</strong
				>, and <strong class="font-bold text-gray-900 dark:text-gray-100"
					>trustworthy machine learning</strong
				>. He is particularly interested in how these fields converge to create reliable AI-based
				systems that <strong class="font-bold text-gray-900 dark:text-gray-100"
					>advance human health</strong
				>.
			</p>
		</div>

		<div class="mb-12 flex flex-col gap-0">
			<div
				id="email-toggle"
				class="group flex w-fit cursor-pointer items-center gap-2 text-gray-900 transition-colors select-none hover:text-gray-500 dark:text-gray-100 dark:hover:text-gray-400"
			>
				<span>Email</span>
				<div
					id="email-container"
					class="flex max-w-0 items-center gap-4 overflow-hidden opacity-0 transition-all duration-500 ease-in-out"
				>
					<span
						id="email-display"
						class="font-mono text-xs whitespace-nowrap text-gray-500 dark:text-gray-400"></span>
					<button
						class="copy-email rounded bg-gray-200 px-2 py-1 text-[10px] font-bold text-gray-900 transition-colors hover:bg-gray-300 dark:bg-white/10 dark:text-gray-100 dark:hover:bg-white/20"
						data-u="young.sang.choi"
						data-d="columbia"
						data-t="edu"
					>
						Copy
					</button>
				</div>
				<span id="email-arrow" class="inline-block transition-transform duration-300">→</span>
			</div>

			<a
				href="/young_sang_choi_cv.pdf"
				class="group flex w-fit items-center gap-2 text-gray-900 transition-colors hover:text-gray-500 dark:text-gray-100 dark:hover:text-gray-400"
				target="_blank"
			>
				<span>Current CV →</span>
			</a>
			<a
				href="https://scholar.google.com/citations?hl=en&user=cX-zhzAAAAAJ"
				class="group flex w-fit items-center gap-2 text-gray-900 transition-colors hover:text-gray-500 dark:text-gray-100 dark:hover:text-gray-400"
				target="_blank"
				rel="noopener noreferrer"
			>
				<span>Google Scholar →</span>
			</a>
			<a
				href="https://github.com/youngsangchoi"
				class="group flex w-fit items-center gap-2 text-gray-900 transition-colors hover:text-gray-500 dark:text-gray-100 dark:hover:text-gray-400"
				target="_blank"
				rel="noopener noreferrer"
			>
				<span>GitHub →</span>
			</a>
			<a
				href="https://www.linkedin.com/in/youngsangchoi/"
				class="group flex w-fit items-center gap-2 text-gray-900 transition-colors hover:text-gray-500 dark:text-gray-100 dark:hover:text-gray-400"
				target="_blank"
				rel="noopener noreferrer"
			>
				<span>LinkedIn →</span>
			</a>
		</div>

		<div class="mb-8">
			<h2 class="mb-6 text-sm font-bold tracking-widest text-gray-400 uppercase">Selected Works</h2>
			<ul class="flex flex-col gap-8">
				{
					publications.map((paper, index) => (
						<li class="flex flex-col gap-2 text-base">
							<h3 class="font-bold text-gray-900 dark:text-gray-100" set:html={paper.title} />
							<div class="leading-relaxed text-gray-500 dark:text-gray-400">
								<span set:html={paper.authors} />
							</div>
							<div class="text-gray-500 dark:text-gray-400">{paper.venue}</div>

							<div>
								<div class="mt-2 flex flex-wrap gap-4 text-sm font-bold text-gray-900 dark:text-gray-100">
									{paper.links.map((link) => (
										<a
											href={link.href}
											class="transition-colors hover:text-gray-500 dark:hover:text-gray-400"
											target="_blank"
											rel="noopener noreferrer"
										>
											{link.text}
										</a>
									))}
									{paper.bibtex && (
										<button
											class="toggle-bibtex flex cursor-pointer items-center gap-1 transition-colors outline-none select-none hover:text-gray-500 dark:hover:text-gray-400"
											data-target={`bibtex-${index}`}
										>
											BibTeX{" "}
											<span class="bibtex-arrow inline-block transition-transform duration-300">
												→
											</span>
										</button>
									)}
								</div>

								{paper.bibtex && (
									<div
										id={`bibtex-${index}`}
										class="relative mt-4 max-h-0 w-full overflow-hidden bg-gray-50 opacity-0 transition-all duration-500 ease-in-out dark:bg-white/5"
									>
										<div class="p-4">
											<button
												class="copy-bibtex absolute top-4 right-4 rounded bg-gray-200 px-2 py-1 text-[10px] font-bold text-gray-900 transition-colors hover:bg-gray-300 dark:bg-white/10 dark:text-gray-100 dark:hover:bg-white/20"
												data-bibtex={paper.bibtex}
											>
												Copy
											</button>
											<pre class="text-left font-mono text-[10px] leading-relaxed whitespace-pre-wrap text-gray-700 sm:text-xs dark:text-gray-300">
												<code set:text={paper.bibtex} />
											</pre>
										</div>
									</div>
								)}
							</div>
						</li>
					))
				}
			</ul>
		</div>
	</section>
</PageLayout>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const toggle = document.getElementById("email-toggle");
		const container = document.getElementById("email-container");
		const arrow = document.getElementById("email-arrow") as HTMLElement;
		const display = document.getElementById("email-display");
		const copyBtn = document.querySelector(".copy-email") as HTMLElement;

		if (copyBtn && display) {
			const u = copyBtn.getAttribute("data-u");
			const d = copyBtn.getAttribute("data-d");
			const t = copyBtn.getAttribute("data-t");
			display.textContent = `${u}@${d}.${t}`;
		}

		toggle?.addEventListener("click", () => {
			const isClosed = container?.classList.contains("max-w-0");
			if (isClosed) {
				container?.classList.replace("max-w-0", "max-w-md");
				container?.classList.replace("opacity-0", "opacity-100");
				if (arrow) arrow.style.transform = "rotate(180deg)";
			} else {
				container?.classList.replace("max-w-md", "max-w-0");
				container?.classList.replace("opacity-100", "opacity-0");
				if (arrow) arrow.style.transform = "rotate(0deg)";
			}
		});

		copyBtn?.addEventListener("click", (e) => {
			e.stopPropagation();
			const u = copyBtn.getAttribute("data-u");
			const d = copyBtn.getAttribute("data-d");
			const t = copyBtn.getAttribute("data-t");
			const email = `${u}@${d}.${t}`;
			if (email) {
				navigator.clipboard.writeText(email).then(() => {
					const originalText = copyBtn.textContent;
					copyBtn.textContent = "Copied!";
					setTimeout(() => {
						copyBtn.textContent = originalText;
					}, 2000);
				});
			}
		});
	});

	document.querySelectorAll(".toggle-bibtex").forEach((btn) => {
		btn.addEventListener("click", () => {
			const targetId = btn.getAttribute("data-target");
			const arrow = btn.querySelector(".bibtex-arrow") as HTMLElement;
			if (targetId) {
				const targetEl = document.getElementById(targetId);
				if (targetEl) {
					const isClosed = targetEl.classList.contains("max-h-0");
					if (isClosed) {
						targetEl.classList.replace("max-h-0", "max-h-[500px]");
						targetEl.classList.replace("opacity-0", "opacity-100");
						if (arrow) arrow.style.transform = "rotate(90deg)";
					} else {
						targetEl.classList.replace("max-h-[500px]", "max-h-0");
						targetEl.classList.replace("opacity-100", "opacity-0");
						if (arrow) arrow.style.transform = "rotate(0deg)";
					}
				}
			}
		});
	});

	document.querySelectorAll(".copy-bibtex").forEach((button) => {
		button.addEventListener("click", () => {
			const bibtex = button.getAttribute("data-bibtex");
			if (bibtex) {
				navigator.clipboard.writeText(bibtex).then(() => {
					const originalText = button.textContent;
					button.textContent = "Copied!";
					setTimeout(() => {
						button.textContent = originalText;
					}, 2000);
				});
			}
		});
	});
</script>
